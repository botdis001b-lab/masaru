<!DOCTYPE html>
<html>
<head>
    <style>
        body { margin: 0; font-family: sans-serif; background: #23272a; color: white; display: flex; }
        .sidebar { width: 240px; background: #2c2f33; height: 100vh; position: fixed; }
        .main { flex: 1; margin-left: 240px; padding: 40px; }
        .card { background: #2f3136; padding: 20px; border-radius: 10px; border-left: 5px solid #f1c40f; }
    </style>
</head>
<body>
    <div class="sidebar">
        <div style="padding: 25px; font-weight: bold; color: #f1c40f;">ADMIN CONSOLE</div>
        <a href="/profile" style="padding: 15px 25px; display: block; color: white; text-decoration: none;">🏠 กลับหน้าหลัก</a>
    </div>
    <div class="main">
        <h1>🛠️ ตั้งค่าบอท</h1>
        <div class="card">
            <div>ผู้ใช้งานทั้งหมด</div>
            <div style="font-size: 30px; font-weight: bold;"><%= totalUsers %> คน</div>
        </div>
    </div>
</body>
</html>