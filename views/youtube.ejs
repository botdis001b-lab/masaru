<!DOCTYPE html>
<html>
<head>
    <style>
        body { margin: 0; font-family: sans-serif; background: #23272a; color: white; display: flex; }
        .sidebar { width: 240px; background: #2c2f33; height: 100vh; position: fixed; }
        .nav-item { padding: 15px 25px; display: block; color: #b9bbbe; text-decoration: none; }
        .main { flex: 1; margin-left: 240px; padding: 40px; }
        .yt-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
        .yt-card { background: #18191c; border-radius: 10px; overflow: hidden; border: 1px solid #444; }
        .yt-thumb { width: 100%; }
    </style>
</head>
<body>
    <div class="sidebar">
        <div style="padding: 25px; font-weight: bold; color: #5865f2;">MASARU BOT</div>
        <a href="/profile" class="nav-item">🏠 หน้าหลัก</a>
        <a href="/youtube" class="nav-item" style="background: #3c3f44;">🎥 วิดีโอ YouTube</a>
        <a href="/logout" class="nav-item" style="color: #ed4245;">🚪 ออกจากระบบ</a>
    </div>
    <div class="main">
        <h2 style="color: #ff0000;">🎥 คลิปใหม่ล่าสุด</h2>
        <div class="yt-grid">
            <% videos.forEach(v => { %>
                <div class="yt-card">
                    <a href="https://www.youtube.com/watch?v=<%= v.id.videoId %>" target="_blank">
                        <img src="<%= v.snippet.thumbnails.high.url %>" class="yt-thumb">
                        <div style="padding: 10px; color: white; font-size: 13px;"><%= v.snippet.title %></div>
                    </a>
                </div>
            <% }) %>
        </div>
        <div style="margin-top: 40px; text-align: center; border: 2px dashed #444; padding: 30px; border-radius: 15px;">
            <h3 style="color: #b9bbbe;">🔔 รอติดตามคลิปใหม่เร็วๆ นี้...</h3>
        </div>
    </div>
</body>
</html>