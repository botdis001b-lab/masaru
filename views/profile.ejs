<!DOCTYPE html>
<html>
<head>
    <title>Masaru Dashboard</title>
    <style>
        body { margin: 0; font-family: 'Segoe UI', sans-serif; background: #23272a; color: white; display: flex; }
        .sidebar { width: 260px; background: #2c2f33; height: 100vh; position: fixed; border-right: 1px solid #444; display: flex; flex-direction: column; }
        .sidebar-header { padding: 25px; text-align: center; border-bottom: 1px solid #444; font-weight: bold; color: #5865F2; font-size: 20px; }
        .nav-item { padding: 15px 25px; display: block; color: #b9bbbe; text-decoration: none; transition: 0.3s; }
        .nav-item:hover { background: #3c3f44; color: white; }
        .nav-item.active { background: #5865F2; color: white; }
        .admin-nav { color: #f1c40f !important; font-weight: bold; }
        .admin-nav:hover { background: #f1c40f22 !important; }
        
        .main-content { margin-left: 260px; padding: 40px; width: 100%; }
        .profile-card { background: #2c2f33; padding: 40px; border-radius: 20px; max-width: 600px; margin: auto; text-align: center; box-shadow: 0 10px 30px rgba(0,0,0,0.3); border-top: 5px solid #5865F2; }
        .avatar { border-radius: 50%; width: 120px; border: 4px solid #5865F2; margin-bottom: 20px; box-shadow: 0 0 15px rgba(88,101,242,0.5); }
        .stats-grid { display: flex; justify-content: space-around; margin-top: 30px; background: #23272a; padding: 20px; border-radius: 15px; }
        .stat-box h3 { margin: 5px 0; font-size: 24px; }
    </style>
</head>
<body>

    <div class="sidebar">
        <div class="sidebar-header">MASARU BOT</div>
        <a href="/profile" class="nav-item <%= currentPage === 'profile' ? 'active' : '' %>">👤 โปรไฟล์ส่วนตัว</a>
        
        <% if (isAdmin) { %>
            <div style="padding: 20px 25px 5px; color: #555; font-size: 11px; font-weight: bold; letter-spacing: 1px;">OWNER ONLY</div>
            <a href="/admin/manage" class="nav-item admin-nav">🛠️ จัดการระบบบอท</a>
        <% } %>

        <a href="#" class="nav-item">🏆 ตารางอันดับ</a>
        
        <div style="margin-top: auto; border-top: 1px solid #444;">
            <a href="/logout" class="nav-item" style="color: #ed4245;">🚪 ออกจากระบบ</a>
        </div>
    </div>

    <div class="main-content">
        <div class="profile-card">
            <img src="<%= avatarUrl %>" class="avatar">
            <h1 style="margin: 0;"><%= user.username %></h1>
            <p style="color: #72767d;">ID: <%= user.id %></p>
            
            <div class="stats-grid">
                <div class="stat-box">
                    <p style="color: #b9bbbe; margin: 0;">Level</p>
                    <h3 style="color: #f1c40f;"><%= userData.level %></h3>
                </div>
                <div class="stat-box">
                    <p style="color: #b9bbbe; margin: 0;">Total XP</p>
                    <h3 style="color: #5865F2;"><%= userData.xp %></h3>
                </div>
            </div>
        </div>
    </div>
</body>
</html>