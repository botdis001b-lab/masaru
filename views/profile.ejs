<!DOCTYPE html>
<html>
<head>
    <title>Masaru Profile</title>
    <style>
        body { margin: 0; font-family: sans-serif; background: #23272a; color: white; display: flex; }
        .sidebar { width: 240px; background: #2c2f33; height: 100vh; position: fixed; border-right: 1px solid #444; }
        .nav-item { padding: 15px 25px; display: block; color: #b9bbbe; text-decoration: none; }
        .nav-item:hover, .active { background: #3c3f44; color: white; }
        .main { flex: 1; margin-left: 240px; position: relative; }
        .profile-nav { position: absolute; top: 20px; right: 30px; }
        .mini-avatar { width: 45px; border-radius: 50%; border: 2px solid #5865f2; cursor: pointer; }
        .dropdown { position: absolute; right: 0; top: 55px; background: #2f3136; padding: 20px; border-radius: 12px; display: none; width: 180px; border: 1px solid #444; }
        .profile-nav:hover .dropdown { display: block; }
    </style>
    <script>
        document.addEventListener('contextmenu', e => e.preventDefault());
        document.onkeydown = function(e) {
            if (e.keyCode == 123 || (e.ctrlKey && e.shiftKey && (e.keyCode == 73 || e.keyCode == 74)) || (e.ctrlKey && e.keyCode == 85)) return false;
        };
    </script>
</head>
<body>
    <div class="sidebar">
        <div style="padding: 25px; font-weight: bold; color: #5865f2;">MASARU BOT</div>
        <a href="/profile" class="nav-item active">🏠 หน้าหลัก</a>
        <a href="/youtube" class="nav-item">🎥 วิดีโอ YouTube</a>
        <% if (isAdmin) { %><a href="/admin" class="nav-item" style="color: #f1c40f;">🛠️ ตั้งค่าบอท</a><% } %>
        <a href="/logout" class="nav-item" style="color: #ed4245;">🚪 ออกจากระบบ</a>
    </div>
    <div class="main">
        <div class="profile-nav">
            <img src="<%= avatarUrl %>" class="mini-avatar">
            <div class="dropdown">
                <strong><%= user.username %></strong>
                <hr style="border:0; border-top:1px solid #444;">
                <p>Level: <%= userData.level %></p>
                <p>XP: <%= userData.xp %></p>
            </div>
        </div>
    </div>
</body>
</html>