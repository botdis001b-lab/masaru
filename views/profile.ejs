<!DOCTYPE html>
<html>
<head>
    <title>Masaru Dashboard</title>
    <style>
        body { margin: 0; font-family: sans-serif; background: #23272a; color: white; display: flex; }
        .sidebar { width: 250px; background: #2c2f33; height: 100vh; border-right: 1px solid #444; }
        .nav-item { padding: 15px 25px; display: block; color: #b9bbbe; text-decoration: none; }
        .nav-item:hover { background: #3c3f44; color: white; }
        .main { flex: 1; padding: 40px; }
        .yt-card { background: #18191c; border-radius: 12px; overflow: hidden; max-width: 450px; border: 1px solid #444; margin-top: 20px; }
        .yt-thumb { width: 100%; display: block; }
        .yt-info { padding: 15px; }
        .user-nav { position: absolute; top: 20px; right: 40px; display: flex; align-items: center; cursor: pointer; }
        .mini-avatar { width: 35px; border-radius: 50%; margin-right: 10px; border: 2px solid #5865f2; }
    </style>
</head>
<body>
    <div class="sidebar">
        <div style="padding: 30px; font-weight: bold; color: #5865f2; font-size: 20px;">MASARU</div>
        <a href="/profile" class="nav-item">🏠 หน้าหลัก</a>
        <% if (isAdmin) { %><a href="#" class="nav-item" style="color: #f1c40f;">🛠️ ตั้งค่าบอท</a><% } %>
        <a href="/logout" class="nav-item" style="color: #ed4245;">🚪 ออกจากระบบ</a>
    </div>

    <div class="main">
        <div class="user-nav">
            <img src="<%= avatarUrl %>" class="mini-avatar">
            <span><%= user.username %> (Lv.<%= userData.level %>)</span>
        </div>

        <h2>ยินดีต้อนรับครับ, <%= user.username %> 👋</h2>
        
        <div style="margin-top: 40px;">
            <h3 style="color: #ff0000;">🔴 วิดีโอล่าสุดจากช่อง Masaru</h3>
            <% if (latestVideo) { %>
                <div class="yt-card">
                    <a href="https://www.youtube.com/watch?v=<%= latestVideo.id.videoId %>" target="_blank" style="text-decoration: none; color: white;">
                        <img src="<%= latestVideo.snippet.thumbnails.high.url %>" class="yt-thumb">
                        <div class="yt-info">
                            <div style="font-weight: bold;"><%= latestVideo.snippet.title %></div>
                            <div style="font-size: 12px; color: #72767d; margin-top: 5px;">
                                อัปโหลดเมื่อ: <%= new Date(latestVideo.snippet.publishedAt).toLocaleDateString('th-TH') %>
                            </div>
                        </div>
                    </a>
                </div>
            <% } else { %>
                <p style="color: #72767d;">กำลังโหลดข้อมูลจาก YouTube...</p>
            <% } %>
        </div>
    </div>
</body>
</html>