<!DOCTYPE html>
<html>
<head>
    <title>Masaru Dashboard</title>
    <style>
        body { margin: 0; font-family: sans-serif; background: #23272a; color: white; display: flex; }
        /* Sidebar Styles */
        .sidebar { width: 250px; background: #2c2f33; height: 100vh; position: fixed; border-right: 1px solid #444; }
        .sidebar-header { padding: 20px; text-align: center; border-bottom: 1px solid #444; font-weight: bold; color: #5865F2; }
        .nav-item { padding: 15px 25px; display: block; color: #b9bbbe; text-decoration: none; transition: 0.2s; }
        .nav-item:hover { background: #3c3f44; color: white; }
        .nav-item.active { background: #5865F2; color: white; }
        
        /* Main Content */
        .main-content { margin-left: 250px; padding: 40px; width: 100%; }
        .profile-card { background: #2c2f33; padding: 30px; border-radius: 15px; max-width: 500px; margin: auto; text-align: center; border-top: 4px solid #5865F2; }
        .avatar { border-radius: 50%; width: 100px; border: 3px solid #5865F2; margin-bottom: 15px; }
    </style>
</head>
<body>

    <div class="sidebar">
        <div class="sidebar-header">MASARU BOT</div>
        <a href="/profile" class="nav-item <%= currentPage === 'profile' ? 'active' : '' %>">👤 โปรไฟล์</a>
        <a href="#" class="nav-item">🏆 อันดับ (Coming Soon)</a>
        <a href="#" class="nav-item">⚙️ ตั้งค่า (Coming Soon)</a>
        <div style="position: absolute; bottom: 0; width: 100%;">
            <a href="/logout" class="nav-item" style="color: #ed4245;">🚪 ออกจากระบบ</a>
        </div>
    </div>

    <div class="main-content">
        <div class="profile-card">
            <img src="<%= avatarUrl %>" class="avatar">
            <h2>ยินดีต้อนรับ, <%= user.username %></h2>
            <div style="display: flex; justify-content: space-around; margin-top: 20px;">
                <div>
                    <p style="color: #b9bbbe; margin: 0;">Level</p>
                    <h3 style="color: #f1c40f; margin: 5px 0;"><%= userData.level %></h3>
                </div>
                <div>
                    <p style="color: #b9bbbe; margin: 0;">Experience</p>
                    <h3 style="margin: 5px 0;"><%= userData.xp %></h3>
                </div>
            </div>
        </div>
    </div>

</body>
</html>