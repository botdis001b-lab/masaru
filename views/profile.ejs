<!DOCTYPE html>
<html>
<head>
    <title>Masaru Profile</title>
    <style>
        body { margin: 0; font-family: sans-serif; background: #23272a; color: white; display: flex; }
        .sidebar { width: 250px; background: #2c2f33; height: 100vh; border-right: 1px solid #444; position: fixed; }
        .nav-item { padding: 15px 25px; display: block; color: #b9bbbe; text-decoration: none; transition: 0.2s; }
        .nav-item:hover { background: #3c3f44; color: white; }
        .main { flex: 1; margin-left: 250px; padding: 60px; display: flex; justify-content: center; align-items: center; min-height: 80vh; }
        .profile-card { background: #2f3136; padding: 40px; border-radius: 20px; width: 100%; max-width: 600px; text-align: center; box-shadow: 0 10px 30px rgba(0,0,0,0.3); border: 1px solid #444; }
        .avatar { width: 150px; border-radius: 50%; border: 5px solid #5865f2; margin-bottom: 20px; }
        .stats { display: flex; justify-content: space-around; margin-top: 30px; background: #202225; padding: 20px; border-radius: 15px; }
        .stat-box div:first-child { color: #b9bbbe; font-size: 14px; margin-bottom: 5px; }
        .stat-box div:last-child { font-size: 24px; font-weight: bold; color: #f1c40f; }
    </style>
</head>
<body>
    <div class="sidebar">
        <div style="padding: 30px; font-weight: bold; color: #5865f2; font-size: 22px;">MASARU BOT</div>
        <a href="/profile" class="nav-item" style="background: #3c3f44; color: white;">🏠 หน้าหลัก</a>
        <a href="/youtube" class="nav-item">🎥 วิดีโอ YouTube</a>
        <% if (isAdmin) { %><a href="#" class="nav-item" style="color: #f1c40f;">🛠️ ตั้งค่าบอท</a><% } %>
        <a href="/logout" class="nav-item" style="color: #ed4245; margin-top: 20px;">🚪 ออกจากระบบ</a>
    </div>

    <div class="main">
        <div class="profile-card">
            <img src="<%= avatarUrl %>" class="avatar">
            <h1 style="margin: 0;"><%= user.username %></h1>
            <p style="color: #72767d; margin: 10px 0;">ID: <%= user.id %></p>
            
            <div class="stats">
                <div class="stat-box">
                    <div>Level</div>
                    <div><%= userData.level %></div>
                </div>
                <div class="stat-box">
                    <div>Total XP</div>
                    <div style="color: #5865f2;"><%= userData.xp %></div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>