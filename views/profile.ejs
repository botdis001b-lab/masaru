<!DOCTYPE html>
<html>
<head>
    <title>Masaru Dashboard</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body { margin: 0; font-family: 'Segoe UI', sans-serif; background: #23272a; color: white; display: flex; min-height: 100vh; overflow: hidden; }
        
        /* Sidebar */
        .sidebar { width: 240px; background: #2c2f33; border-right: 1px solid #444; position: fixed; height: 100%; z-index: 100; }
        .sidebar-header { padding: 30px 25px; font-weight: bold; color: #5865f2; font-size: 20px; }
        .nav-item { padding: 15px 25px; display: flex; align-items: center; color: #b9bbbe; text-decoration: none; transition: 0.2s; }
        .nav-item:hover, .nav-item.active { background: #3c3f44; color: white; }
        .nav-icon { margin-right: 12px; }

        /* พื้นที่หลัก (ตอนนี้จะว่างๆ เท่ๆ เลยครับ) */
        .main { flex: 1; margin-left: 240px; position: relative; min-height: 100vh; background: url('https://www.transparenttextures.com/patterns/dark-matter.png'); }

        /* --- ส่วนจัดการโปรไฟล์มุมขวาบน --- */
        .profile-menu { 
            position: absolute; 
            top: 20px; 
            right: 30px; 
            z-index: 1000;
        }

        /* ปุ่มรูปโปรไฟล์ */
        .profile-trigger {
            display: flex; 
            align-items: center; 
            background: #2f3136;
            padding: 5px 15px 5px 5px;
            border-radius: 50px;
            border: 1px solid #444;
            cursor: pointer;
            transition: 0.3s;
        }
        .profile-trigger:hover { background: #3c3f44; border-color: #5865f2; }
        
        .mini-avatar { 
            width: 35px; 
            height: 35px; 
            border-radius: 50%; 
            border: 2px solid #5865f2; 
            margin-right: 10px;
        }
        .top-username { font-size: 14px; font-weight: 500; }

        /* กล่องข้อมูลที่จะเด้งออกมา (Dropdown) */
        .profile-dropdown {
            position: absolute;
            top: 55px;
            right: 0;
            width: 220px;
            background: #2f3136;
            border-radius: 15px;
            border: 1px solid #444;
            box-shadow: 0 10px 25px rgba(0,0,0,0.5);
            padding: 20px;
            display: none; /* ซ่อนไว้ก่อน */
            animation: fadeIn 0.2s ease;
        }

        /* แสดงเมื่อเอาเมาส์ชี้ */
        .profile-menu:hover .profile-dropdown { display: block; }

        .dropdown-id { color: #72767d; font-size: 11px; margin-bottom: 15px; display: block; }
        
        .stat-row { 
            display: flex; 
            justify-content: space-between; 
            padding: 8px 0;
            border-top: 1px solid #444;
        }
        .stat-label { color: #b9bbbe; font-size: 13px; }
        .stat-val { font-weight: bold; }
        .color-lv { color: #f1c40f; }
        .color-xp { color: #5865f2; }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-header">MASARU BOT</div>
        <a href="/profile" class="nav-item active"><span class="nav-icon">🏠</span> หน้าหลัก</a>
        <a href="/youtube" class="nav-item"><span class="nav-icon">🎥</span> วิดีโอ YouTube</a>
        <% if (isAdmin) { %>
            <a href="#" class="nav-item" style="color: #f1c40f;"><span class="nav-icon">🛠️</span> ตั้งค่าบอท</a>
        <% } %>
        <a href="/logout" class="nav-item" style="color: #ed4245; margin-top: 20px;"><span class="nav-icon">🚪</span> ออกจากระบบ</a>
    </div>

    <div class="main">
        <div class="profile-menu">
            <div class="profile-trigger">
                <img src="<%= avatarUrl %>" class="mini-avatar">
                <span class="top-username"><%= user.username %></span>
            </div>

            <div class="profile-dropdown">
                <strong style="display: block; font-size: 16px;"><%= user.username %></strong>
                <span class="dropdown-id">ID: <%= user.id %></span>
                
                <div class="stat-row">
                    <span class="stat-label">Level</span>
                    <span class="stat-val color-lv"><%= userData.level %></span>
                </div>
                <div class="stat-row">
                    <span class="stat-label">Experience</span>
                    <span class="stat-val color-xp"><%= userData.xp %> XP</span>
                </div>
            </div>
        </div>

        </div>
</body>
</html>